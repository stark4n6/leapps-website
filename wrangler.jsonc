{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "leapps-website",
  "compatibility_date": "2026-06-25",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    // Serve /releases from releases.html and redirect /releases.html -> /releases
    "html_handling": "auto-trailing-slash",
    // Serve our custom 404.html on unknown paths instead of a bare 404
    "not_found_handling": "404-page"
  }
}
