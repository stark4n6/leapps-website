# Cache-Control for static assets served by Cloudflare.
# HTML, JSON and Markdown are intentionally left at the default
# (revalidate) so deploys and content edits show immediately.

# Images rarely change — cache for 30 days.
/img/*
  Cache-Control: public, max-age=2592000
/logos/*
  Cache-Control: public, max-age=2592000

# Per-post social cards — 1 hour. Short on purpose: this rule also lands on
# a 404 if a card is ever requested before it deploys, so a brief cache keeps
# a stray 404 from sticking for a day.
/blog/og/*
  Cache-Control: public, max-age=3600

# The analytics loader — 1 hour.
/analytics.js
  Cache-Control: public, max-age=3600

# Shared stylesheet — 1 hour, so cross-page navigation reuses it.
/css/*
  Cache-Control: public, max-age=3600
